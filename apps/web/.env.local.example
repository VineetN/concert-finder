# Next.js reads this file automatically. Copy to .env.local and fill in values.
# Most values mirror the root .env — kept separate so Next.js hot-reload picks
# them up without restarting the API server.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=          # same value as NEXTAUTH_SECRET

# Must match the port Next.js runs on (just web → :3000)
AUTH_URL=http://127.0.0.1:3000/api/auth
AUTH_TRUST_HOST=true

# URL of the FastAPI backend (just api → :8000)
API_URL=http://127.0.0.1:8000
