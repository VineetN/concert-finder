# ── Spotify OAuth ─────────────────────────────────────────────────────────────
# These credentials serve TWO purposes:
#   1. User OAuth flow (NextAuth, frontend login)
#   2. Worker enrichment — the worker auto-fetches a fresh client_credentials
#      token before each pipeline run using these same values.
#      No separate SPOTIFY_CLIENT_TOKEN variable is needed.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Redirect URI registered in your Spotify app dashboard:
#   http://localhost:3000/api/auth/callback/spotify
NEXTAUTH_SECRET=          # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required only for HF Inference API fallback (LLM explanations).
# Free tier works fine for 2 users. Get a token at huggingface.co/settings/tokens
HF_TOKEN=

# ── DB Sync (Litestream → Cloudflare R2) ──────────────────────────────────────
# Free tier: 10 GB storage, 1M Class A ops/month — more than enough.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=concert-finder-db
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL=../../data/concert.db
API_PORT=8000
# CORS origin for the frontend (change for Tailscale hostname in prod)
FRONTEND_URL=http://localhost:3000
