# ── Spotify OAuth ─────────────────────────────────────────────────────────────
# Create a Spotify app at https://developer.spotify.com/dashboard
# Add this redirect URI: http://127.0.0.1:3000/api/auth/callback/spotify
# (must be 127.0.0.1 — Spotify blocks "localhost")
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── NextAuth (Auth.js v5) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=          # same value as NEXTAUTH_SECRET

# ── Last.fm ───────────────────────────────────────────────────────────────────
# Used for artist genre tags (Spotify stripped genres from its API in Nov 2024).
# Free API key at https://www.last.fm/api/account/create (no callback URL needed)
LASTFM_API_KEY=

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional — enables one-sentence LLM explanations on each recommendation.
# Free tier at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── DB Sync (Litestream → Cloudflare R2) ──────────────────────────────────────
# Only needed for production two-node setup. Skip for local dev.
# Free tier: 10 GB storage — more than enough.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=concert-finder-db
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ── API ───────────────────────────────────────────────────────────────────────
# DATABASE_URL defaults to data/concert.db relative to repo root — omit unless
# you want to point at a different path.
# DATABASE_URL=data/concert.db
FRONTEND_URL=http://localhost:3000
